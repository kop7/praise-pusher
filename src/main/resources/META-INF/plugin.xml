<idea-plugin>
    <id>com.kop.praisepusher</id>
    <name>Praise Pusher</name>

    <vendor email="matija.kop1@gmail.com" url="https://github.com/kop7">Matija</vendor>

    <description>
        Shows a friendly motivational message after a successful Git push.
    </description>

    <idea-version since-build="253"/>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.vcs</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <notificationGroup
            id="Praise Pusher"
            displayType="BALLOON"
            isLogByDefault="true"/>
        <postStartupActivity implementation="com.kop.praisepusher.PraisePusherProjectActivity"/>
        <checkinHandlerFactory implementation="com.kop.praisepusher.GitCommitPraiseHandlerFactory"/>
    </extensions>
</idea-plugin>
